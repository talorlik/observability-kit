{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cluster Profile",
  "type": "object",
  "required": [
    "profile_id",
    "kubernetes_version",
    "distribution",
    "prerequisites"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "kubernetes_version": {
      "type": "string",
      "enum": [
        "1.28",
        "1.29",
        "1.30"
      ]
    },
    "distribution": {
      "type": "string",
      "enum": [
        "eks",
        "gke",
        "aks",
        "kubeadm",
        "openshift"
      ]
    },
    "prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
