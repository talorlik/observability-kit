{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storage Profile",
  "type": "object",
  "required": [
    "profile_id",
    "storage_class",
    "access_mode",
    "prerequisites"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "enum": [
        "gp3-csi",
        "standard-rwo",
        "nfs-rwx"
      ]
    },
    "storage_class": {
      "type": "string",
      "minLength": 1
    },
    "access_mode": {
      "type": "string",
      "enum": [
        "ReadWriteOnce",
        "ReadWriteMany"
      ]
    },
    "prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
