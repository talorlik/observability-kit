{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Secrets Profile",
  "type": "object",
  "required": [
    "profile_id",
    "backend",
    "rotation_policy",
    "prerequisites"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "enum": [
        "external-secrets",
        "vault",
        "sealed-secrets"
      ]
    },
    "backend": {
      "type": "string",
      "enum": [
        "external-secrets",
        "vault",
        "sealed-secrets"
      ]
    },
    "rotation_policy": {
      "type": "string",
      "enum": [
        "automatic",
        "manual"
      ]
    },
    "prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
