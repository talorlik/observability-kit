{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://observability-kit/contracts/ai/AGENT_ENVELOPE_V1.json",
  "title": "AgentEnvelopeV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "objective",
    "findings",
    "evidence_handles",
    "assumptions",
    "confidence",
    "risk_level",
    "recommended_next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_handles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "recommended_next_action": {
      "type": "string",
      "minLength": 1
    }
  }
}
