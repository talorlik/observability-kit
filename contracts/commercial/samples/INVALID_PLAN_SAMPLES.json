{
  "description": "Seeded rejection samples for PLAN_CATALOG_V1.yaml (Batch 22 Task 3). Every sample must be REJECTED by the plan-catalog compliance rules (contracts/commercial/PLAN_CATALOG_V1.yaml rules.compliance) or by scripts/ci/validate_commercial_contracts.sh; a sample that validates cleanly is a validator failure. Structured self-describingly, like INVALID_USAGE_RECORD_SAMPLES.json, so a validator script can iterate it.",
  "samples": [
    {
      "name": "plan-missing-quota-bounds",
      "expected_rejection": "fail_if_plan_missing_quota_bounds: a plan with no quota_bounds object is rejected",
      "payload": {
        "plan_id": "plan-starter-broken",
        "display_name": "Starter (broken)",
        "tier": "starter",
        "billing": {
          "pricing_model": "base-plus-overage",
          "currency_neutral": true,
          "base_monthly_units": 100
        },
        "metered_dimensions": [
          "ingest_gb_per_day",
          "retention_days",
          "active_tenants",
          "query_volume"
        ]
      }
    },
    {
      "name": "plan-tier-outside-tenant-schema-enum",
      "expected_rejection": "fail_if_plan_tier_not_in_tenant_schema_enum: tier value 'ultimate' is not a member of the enum at contracts/tenancy/TENANT_CONTRACT_SCHEMA_V1.json /properties/tier/enum",
      "payload": {
        "plan_id": "plan-ultimate",
        "display_name": "Ultimate",
        "tier": "ultimate",
        "quota_bounds": {
          "quotas.ingest.max_gb_per_day": {
            "min": 5000,
            "max": 10000
          },
          "quotas.ingest.max_events_per_second": {
            "min": 100000,
            "max": 200000
          },
          "quotas.retention.logs_days": {
            "min": 365,
            "max": 3650
          },
          "quotas.retention.metrics_days": {
            "min": 365,
            "max": 3650
          },
          "quotas.retention.traces_days": {
            "min": 365,
            "max": 3650
