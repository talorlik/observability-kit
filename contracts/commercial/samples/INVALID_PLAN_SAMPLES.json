        "billing": {
          "pricing_model": "base-plus-overage",
          "currency_neutral": true,
          "base_monthly_units": 8000
        },
        "metered_dimensions": [
          "ingest_gb_per_day",
          "retention_days",
          "active_tenants",
          "query_volume"
        ]
      }
    },
    {
      "name": "tenant-quota-exceeds-plan-bound",
      "expected_rejection": "fail_if_tenant_quota_exceeds_plan_bound: tenant quotas.ingest.max_gb_per_day (150) exceeds plan-starter's quota_bounds max (25) for its bound tier 'starter'",
      "payload": {
        "tenant": {
          "tenant_id": "wonka-industries",
          "tier": "starter",
          "quotas": {
            "ingest": {
              "max_gb_per_day": 150,
              "max_events_per_second": 300
