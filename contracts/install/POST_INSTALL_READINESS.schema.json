{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post Install Readiness Report",
  "type": "object",
  "required": [
    "metadata",
    "readiness_sections"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "version",
        "generated_by",
        "emitted_after"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "generated_by": {
          "type": "string",
          "minLength": 1
        },
        "emitted_after": {
          "type": "string",
          "const": "dry-run-install"
        }
      },
      "additionalProperties": true
    },
    "readiness_sections": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "pass",
              "fail"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
