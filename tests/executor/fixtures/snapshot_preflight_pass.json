{
  "cluster": {
    "name": "reference-cluster",
    "kubernetes_version": "1.29",
    "distribution": "kind"
  },
  "connectivity": true,
  "permissions": {
    "list:namespaces": true,
    "list:nodes": true,
    "list:services": true,
    "list:pods": true,
    "list:apps/deployments": true,
    "list:apps/daemonsets": true,
    "list:apps/statefulsets": true,
    "list:storage.k8s.io/storageclasses": true,
    "list:networking.k8s.io/ingressclasses": true,
    "list:apiextensions.k8s.io/customresourcedefinitions": true,
    "list:apiregistration.k8s.io/apiservices": true,
    "list:batch/cronjobs": true
  },
  "api_versions": [
    "v1",
    "apps/v1",
    "batch/v1",
    "rbac.authorization.k8s.io/v1",
    "storage.k8s.io/v1",
    "networking.k8s.io/v1",
    "apiextensions.k8s.io/v1",
    "apiregistration.k8s.io/v1"
  ],
  "crds": [
    "applications.argoproj.io",
    "applicationsets.argoproj.io",
    "appprojects.argoproj.io",
    "gatewayclasses.gateway.networking.k8s.io",
    "gateways.gateway.networking.k8s.io",
    "httproutes.gateway.networking.k8s.io"
  ],
  "storage_classes": [
    {
      "name": "standard",
      "provisioner": "kubernetes.io/no-provisioner",
      "default": true
    }
  ],
  "ingress_classes": [
    {
      "name": "reference-ingress",
      "controller": "k8s.io/ingress-nginx"
    }
  ],
  "namespaces": [
    "argocd",
    "default",
    "kube-system"
  ],
  "workloads": [
    {
      "namespace": "argocd",
      "name": "argocd-application-controller",
      "kind": "StatefulSet"
    },
    {
      "namespace": "argocd",
      "name": "argocd-repo-server",
      "kind": "Deployment"
    }
  ],
  "services": []
}
