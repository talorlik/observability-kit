  "rules": {
    "compliance": {
      "fail_if_plan_missing_quota_bounds": {
        "severity": "error",
        "description": "A plan without a quota_bounds object, or with an empty quota_bounds object, is rejected. Every plan must bound all five tenant quota fields."
      },
      "fail_if_plan_tier_not_in_tenant_schema_enum": {
        "severity": "error",
        "description": "A plan whose tier value is not a member of the enum at tier_binding.source_pointer in contracts/tenancy/TENANT_CONTRACT_SCHEMA_V1.json is rejected."
      },
      "fail_if_duplicate_tier_binding": {
        "severity": "error",
        "description": "Two or more plans bound to the same tier value is rejected; the mapping from tier to plan must be one-to-one (tier_binding.mapping_shape: bijective)."
      },
      "fail_if_quota_bound_outside_tenant_schema_range": {
        "severity": "error",
        "description": "A quota_bounds entry whose min or max falls outside the corresponding field's range in contracts/tenancy/TENANT_CONTRACT_SCHEMA_V1.json (ingest fields: exclusiveMinimum 0 / integer >= 1; retention fields: integer 1..3650) is rejected."
      },
      "fail_if_tenant_quota_exceeds_plan_bound": {
        "severity": "error",
        "description": "A tenant descriptor whose quotas value for any of the five bound fields falls outside the [min, max] range of the plan bound to the tenant's tier fails validation. Enforcement of an existing breach is a lifecycle action executed through the Batch 20 control plane, per contracts/commercial/METERING_CONTRACT_V1.yaml quota_breach_handling; this rule governs admission-time validation of the descriptor against its plan."
      },
      "fail_if_metered_dimension_not_in_metering_contract": {
        "severity": "error",
        "description": "A plan's metered_dimensions list containing a dimension id not present in the dimensions catalog of contracts/commercial/METERING_CONTRACT_V1.yaml is rejected."
      }
    },
    "schema_versioning": "This contract is versioned via the _V1 filename suffix per contracts/CONTRACTS_NAMING_CONVENTION.md. Breaking changes to the tier-binding shape, the quota_bounds field set, or the compliance rules require a new PLAN_CATALOG_V<N>.yaml plus documented migration notes before release. Never rename this file."
  }
}
